        "name": "推薦結果（列表）",
        "order": 1,
        "width": 17,
        "height": 17,
        "format": "<div>\n  <div style=\"display:flex; justify-content:space-between; align-items:center;\">\n    <h3>親愛的 {{msg.payload.userInfo.name}}，前往「{{msg.payload.userInfo.destination}}」的計畫：</h3>\n    <div style=\"background:#e0f7fa; padding:5px 10px; border-radius:15px; color:#006064; font-size:0.9em;\">\n        {{msg.payload.weather.icon}} {{msg.payload.weather.temp}}°C {{msg.payload.weather.status}}\n    </div>\n  </div>\n  <div style=\"color:#666; font-size:0.9em; margin-bottom:15px;\">\n      💡 小貼士：{{msg.payload.weather.tip}}\n  </div>\n  \n  <!-- 交通卡片區 -->\n  <div style=\"display:flex; flex-wrap:wrap; gap:10px; margin-bottom:20px;\">\n      \n      <!-- 開車 (藍色) -->\n      <div style=\"flex:1; min-width:140px; background:#e3f2fd; padding:10px; border-radius:8px; border-left:5px solid #2196f3\">\n          <div style=\"font-weight:bold; color:#1565c0\"><i class=\"fa fa-car\"></i> 自行開車</div>\n          <div style=\"font-size:1.2em; margin:5px 0\">{{msg.payload.estimates.car.time}}</div>\n          <div style=\"font-size:0.9em; color:#555\">{{msg.payload.estimates.car.price}}</div>\n      </div>\n\n      <!-- 高鐵 (根據 valid 顯示或隱藏) -->\n      <div style=\"flex:1; min-width:140px; padding:10px; border-radius:8px; border-left:5px solid;\" \n           ng-if=\"msg.payload.estimates.hsr.valid\"\n           ng-style=\"{'background': '#fff3e0', 'border-color': '#ff9800'}\">\n          <div style=\"font-weight:bold; color: #ef6c00;\">\n               <i class=\"fa fa-train\"></i> 高鐵\n          </div>\n          <div style=\"font-size:1.2em; margin:5px 0; color: #000;\">\n               {{msg.payload.estimates.hsr.time}}\n          </div>\n          <div style=\"font-size:0.9em; color:#555\">{{msg.payload.estimates.hsr.price}}</div>\n      </div>\n      \n      <!-- 台鐵 (綠色) -->\n      <div style=\"flex:1; min-width:140px; background:#e8f5e9; padding:10px; border-radius:8px; border-left:5px solid #4caf50\">\n          <div style=\"font-weight:bold; color:#2e7d32\"><i class=\"fa fa-subway\"></i> 台鐵火車</div>\n          <div style=\"font-size:1.2em; margin:5px 0\">{{msg.payload.estimates.tra.time}}</div>\n          <div style=\"font-size:0.9em; color:#555\">{{msg.payload.estimates.tra.price}}</div>\n      </div>\n\n      <!-- 公車 (紫色) -->\n      <div style=\"flex:1; min-width:140px; background:#f3e5f5; padding:10px; border-radius:8px; border-left:5px solid #9c27b0\">\n          <div style=\"font-weight:bold; color:#7b1fa2\"><i class=\"fa fa-bus\"></i> 公車客運</div>\n          <div style=\"font-size:1.2em; margin:5px 0\">{{msg.payload.estimates.bus.time}}</div>\n          <div style=\"font-size:0.9em; color:#555\">{{msg.payload.estimates.bus.price}}</div>\n      </div>\n  </div>\n\n  <h3>{{msg.payload.userInfo.destination}} 精選推薦</h3>\n  <div ng-repeat=\"r in msg.payload.recommendations\" style=\"border-bottom:1px solid #eee; padding:10px 0; display:flex; align-items:center;\">\n    <img id=\"list-img-{{$index}}\" src=\"https://via.placeholder.com/60?text=Loading\" style=\"width:60px; height:60px; border-radius:5px; object-fit:cover; margin-right:15px;\">\n    <div style=\"flex:1;\">\n        <strong style=\"font-size:1.1em\">{{r.name}}</strong>\n        <div style=\"color:#666; font-size:0.9em\">{{r.note}}</div>\n    </div>\n    <div style=\"text-align:right; color:#d84315; font-weight:bold\">\n        {{r.price || r.when || ''}}\n    </div>\n  </div>\n\n  <div style=\"margin-top:20px; text-align:center;\">\n      <button class=\"md-button md-raised md-primary\" \n              ng-click=\"send({payload:{tab:'STEP 4: 地圖與圖片'}})\">\n          查看詳細地圖與美照\n      </button>\n  </div>\n</div>\n\n<script>\n(function(scope){\n  var apiKey = \"AIzaSyAok-Ur1aqmDzkCdt45NSBpNb4wETXEYZc\"; \n  scope.$watch('msg', function(msg){\n    if(!msg || !msg.payload || !msg.payload.recommendations) return;\n    function loadGoogleMaps(cb) {\n      if (window.google && window.google.maps && window.google.maps.places) return cb();\n      if(document.getElementById('gmap-script-list')) return;\n      var script = document.createElement('script');\n      script.id = 'gmap-script-list';\n      script.src = \"https://maps.googleapis.com/maps/api/js?key=\" + apiKey + \"&libraries=places\";\n      script.async = true;\n      script.onload = cb;\n      document.head.appendChild(script);\n    }\n    loadGoogleMaps(function(){\n        var dummyMap = document.createElement('div');\n        var service = new google.maps.places.PlacesService(dummyMap);\n        msg.payload.recommendations.forEach(function(rec, index){\n            var request = { query: rec.query, fields: ['photos'] };\n            service.findPlaceFromQuery(request, function(results, status) {\n                if (status === google.maps.places.PlacesServiceStatus.OK && results && results[0].photos) {\n                     var imgUrl = results[0].photos[0].getUrl({maxWidth: 200});\n                     var imgEl = document.getElementById('list-img-'+index);\n                     if(imgEl) imgEl.src = imgUrl;\n                }\n            });\n        });\n    });\n  });\n})(scope);\n</script>",
