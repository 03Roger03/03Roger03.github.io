        "name": "解析出發 & 準備目的地",
        "func": "if(msg.payload && msg.payload.length > 0){\n    flow.set('start_coords', { lat: msg.payload[0].lat, lon: msg.payload[0].lon });\n} else {\n    flow.set('start_coords', { lat: '25.0478', lon: '121.5170' });\n}\n\nvar end = flow.get('end_place');\nmsg.url = 'https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + encodeURIComponent(end);\nmsg.headers = { 'User-Agent': 'NodeRED-Travel-Bot/1.0' };\nmsg.topic = 'geocode_end';\nreturn msg;",
