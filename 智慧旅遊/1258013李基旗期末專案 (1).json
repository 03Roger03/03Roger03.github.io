    {
        "id": "ab8d42fc374f89ab",
        "type": "function",
        "z": "0754958db1fe8867",
        "name": "準備地理編碼",
        "func": "if(msg.topic === 'start_place') flow.set('start_place', msg.payload);\nif(msg.topic === 'end_place') flow.set('end_place', msg.payload);\nif(msg.topic === 'purpose') flow.set('selected_purpose', msg.payload);\n\nif (msg.topic !== 'search') return null;\n\nvar start = flow.get('start_place');\nvar end = flow.get('end_place');\nif(!start || !end){\n  node.warn('請輸入地點');\n  return null;\n}\n\nmsg.url = 'https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + encodeURIComponent(start);\nmsg.headers = { 'User-Agent': 'NodeRED-Travel-Bot/1.0' };\nmsg.topic = 'geocode_start';\nreturn msg;",
