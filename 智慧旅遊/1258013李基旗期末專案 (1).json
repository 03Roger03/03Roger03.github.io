    {
        "id": "20daa9d4ce8a1e57",
        "type": "function",
        "z": "0754958db1fe8867",
        "name": "建立交通 API 請求 (含天氣)",
        "func": "\n// 存天氣資料\nif(msg.topic === 'weather' && msg.payload && msg.payload.current_weather){\n    flow.set('weather_data', msg.payload.current_weather);\n}\n\nvar start = flow.get('start_place');\nvar s_coord = flow.get('start_coords');\nvar e_coord = flow.get('end_coords');\nvar key = flow.get('tdx_api_key') || '';\n\nvar base = 'https://tdx.transportdata.tw/api/basic/';\nvar busUrl = base + 'Bus/Route/City/Taipei?$filter=contains(RouteName/En,\\''+encodeURIComponent(start)+'\\')';\nvar traUrl = base + 'Rail/TRA/Station?$filter=contains(StationName/En,\\''+encodeURIComponent(start)+'\\')';\nvar hsrUrl = base + 'Rail/HSR/Station?$filter=contains(StationName/En,\\''+encodeURIComponent(start)+'\\')';\n\nvar carUrl = 'https://router.project-osrm.org/route/v1/driving/' + \n             s_coord.lon + ',' + s_coord.lat + ';' + \n             e_coord.lon + ',' + e_coord.lat + '?overview=full';\n\nvar m1 = { topic: 'bus', url: busUrl, headers: { 'authorization': key } };\nvar m2 = { topic: 'tra', url: traUrl, headers: { 'authorization': key } };\nvar m3 = { topic: 'hsr', url: hsrUrl, headers: { 'authorization': key } };\nvar m4 = { topic: 'car', url: carUrl };\n\nreturn [m1,m2,m3,m4,{payload:{tab:'STEP 3: 推薦結果'}}];\n",
