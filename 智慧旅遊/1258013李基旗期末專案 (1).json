    {
        "id": "10ea426ab2854cbd",
        "type": "function",
        "z": "0754958db1fe8867",
        "name": "彙整資料 & 智慧判斷 & 生成關鍵字",
        "func": "\nvar trans = flow.get('transport_results') || {};\nvar carData = flow.get('car_data') || null;\n\n// 儲存原始數據\ntrans[msg.topic] = msg.payload;\n\nif(msg.topic === 'car' && msg.payload.routes && msg.payload.routes.length > 0) {\n    carData = msg.payload.routes[0];\n    flow.set('car_data', carData);\n}\n\nflow.set('transport_results', trans);\ncarData = flow.get('car_data');\n\n// --- 天氣解析 ---\nvar weather = flow.get('weather_data') || {temperature: 25, weathercode: 0};\nvar wCode = weather.weathercode;\nvar wStatus = \"晴天\";\nvar wIcon = \"☀️\";\nvar wTip = \"天氣很棒，適合戶外活動！\";\n\nif (wCode >= 1 && wCode <= 3) { wStatus = \"多雲\"; wIcon = \"☁️\"; wTip = \"舒服的天氣，適合走走。\"; }\nelse if (wCode >= 45 && wCode <= 48) { wStatus = \"起霧\"; wIcon = \"🌫️\"; wTip = \"視線不佳，開車請小心。\"; }\nelse if (wCode >= 51 && wCode <= 67) { wStatus = \"有雨\"; wIcon = \"🌧️\"; wTip = \"建議攜帶雨具，可安排室內行程。\"; }\nelse if (wCode >= 71) { wStatus = \"雷雨/雪\"; wIcon = \"⛈️\"; wTip = \"天氣不穩定，請注意安全。\"; }\n\nvar weatherInfo = {\n    temp: weather.temperature,\n    status: wStatus,\n    icon: wIcon,\n    tip: wTip\n};\n\n\n// --- 計算交通邏輯 & 地理判斷 ---\nvar estimates = {};\nvar e_place = flow.get('end_place') || \"\";\n\n// 建立「無高鐵城市」黑名單\nvar noHsrCities = [\"花蓮\", \"台東\", \"臺東\", \"宜蘭\", \"南投\", \"基隆\", \"屏東\", \"澎湖\", \"金門\", \"馬祖\", \"連江\"];\nvar isHsrAvailable = true;\n\n// 檢查目的地是否在黑名單中\nfor(var k=0; k<noHsrCities.length; k++){\n    if(e_place.indexOf(noHsrCities[k]) > -1){\n        isHsrAvailable = false;\n        break;\n    }\n}\n\nif(carData) {\n    var distKm = carData.distance / 1000;\n    var durationSec = carData.duration;\n    function formatTime(sec) {\n        var h = Math.floor(sec / 3600);\n        var m = Math.floor((sec % 3600) / 60);\n        return (h > 0) ? h + \" 小時 \" + m + \" 分\" : m + \" 分鐘\";\n    }\n    \n    estimates.car = { time: formatTime(durationSec), price: \"油資約 NT$ \" + Math.round(distKm * 3) };\n    \n    // 根據地理位置決定顯示內容\n    if(isHsrAvailable) {\n        estimates.hsr = { \n            time: formatTime(durationSec * 0.4), \n            price: \"票價約 NT$ \" + Math.round(distKm * 4.5),\n            valid: true\n        };\n    } else {\n        estimates.hsr = { \n            time: \"未開通\", \n            price: \"無高鐵直達\",\n            valid: false\n        };\n    }\n    \n    estimates.tra = { time: formatTime(durationSec * 0.8), price: \"票價約 NT$ \" + Math.round(distKm * 2.2) };\n    estimates.bus = { time: formatTime(durationSec * 1.5), price: \"票價約 NT$ \" + Math.round(distKm * 1.8) };\n} else {\n    estimates = { car: {time: \"--\", price: \"--\"}, hsr: {time: \"--\", price: \"--\"}, tra: {time: \"--\", price: \"--\"}, bus: {time: \"--\", price: \"--\"} };\n}\n\n// --- 推薦內容 (生成真實類別搜尋關鍵字) ---\nvar purpose = flow.get('selected_purpose') || 'food';\nvar people = flow.get('people') || 1;\nvar userName = flow.get('user_name') || '旅客';\nvar e_coord = flow.get('end_coords'); \nvar s_place = flow.get('start_place');\nvar centerLat = parseFloat(e_coord.lat);\nvar centerLon = parseFloat(e_coord.lon);\n\nvar recs = [];\nvar baseRecs = [];\n\n// 關鍵修改：根據不同目的，產生完全不同的搜索關鍵字\n// 這樣前端 Google Maps 搜出來的點位就會完全不同\nif(purpose==='food'){\n  baseRecs.push({name: '在地必吃美食', price:'NT$50-120', note:'網友熱推', query: e_place + ' 必吃美食'});\n  baseRecs.push({name: '特色主題餐廳', price:'NT$200-500', note:'氣氛佳', query: e_place + ' 特色餐廳'});\n  baseRecs.push({name: '人氣甜點/咖啡', price:'NT$100-300', note:'下午茶首選', query: e_place + ' 甜點 咖啡'});\n  baseRecs.push({name: '夜市小吃', price:'NT$30-150', note:'宵夜好去處', query: e_place + ' 夜市'});\n} else if(purpose==='stay'){\n  baseRecs.push({name: '精選星級飯店', note:'舒適享受', query: e_place + ' 飯店'});\n  baseRecs.push({name: '特色風格民宿', note:'體驗在地生活', query: e_place + ' 民宿'});\n  baseRecs.push({name: '平價青年旅館', note:'背包客首選', query: e_place + ' 青年旅館'});\n  baseRecs.push({name: '度假村/溫泉旅店', note:'放鬆身心', query: e_place + ' 度假村'});\n} else if(purpose==='photo'){\n  baseRecs.push({name: '熱門打卡景點', note:'拍照聖地', query: e_place + ' 景點'});\n  baseRecs.push({name: '自然風景區', note:'風景優美', query: e_place + ' 風景區'});\n  baseRecs.push({name: '歷史古蹟', note:'文化氣息', query: e_place + ' 古蹟'});\n  baseRecs.push({name: '私房秘境', note:'人少好逛', query: e_place + ' 秘境'});\n} else { // fun\n  baseRecs.push({name: '遊樂園/休閒農場', note:'親子同樂', query: e_place + ' 遊樂園'});\n  baseRecs.push({name: '博物館/美術館', note:'知性之旅', query: e_place + ' 博物館'});\n  baseRecs.push({name: '戶外體驗活動', note:'刺激好玩', query: e_place + ' 體驗活動'});\n  baseRecs.push({name: '購物中心/商圈', note:'逛街血拼', query: e_place + ' 購物中心'});\n}\n\nbaseRecs.forEach(function(r, i){\n    var n = r.note;\n    if(people > 5) n += \" (適合多人)\";\n    if(wCode >= 50 && purpose !== 'food') n += \" (雨天備案：室內參觀)\";\n    r.note = n;\n    recs.push(r);\n});\n\nvar map = { lat: centerLat, lng: centerLon, pins: recs };\nvar out = { payload: { \n    transport: trans, \n    estimates: estimates, \n    recommendations: recs, \n    map: map,\n    weather: weatherInfo,\n    userInfo: { name: userName, people: people, start: s_place, destination: e_place }\n}};\n\nreturn [out, out];\n",
