        "type": "function",
        "z": "0754958db1fe8867",
        "name": "儲存目的地 & 準備天氣",
        "func": "if(msg.payload && msg.payload.length > 0){\n    flow.set('end_coords', { lat: msg.payload[0].lat, lon: msg.payload[0].lon });\n} else {\n    flow.set('end_coords', { lat: '23.85', lon: '120.91' });\n}\n\nvar ecoord = flow.get('end_coords');\n// 準備天氣 API (Open-Meteo)\nmsg.url = `https://api.open-meteo.com/v1/forecast?latitude=${ecoord.lat}&longitude=${ecoord.lon}&current_weather=true&timezone=auto`;\nmsg.topic = 'weather';\nreturn msg;",
